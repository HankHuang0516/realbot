# Shared secret with E-Claw backend (must match backend's SUPPORT_API_KEY)
SUPPORT_API_KEY=your-shared-secret-here

# Port (Railway auto-assigns, default 4000 for local)
PORT=4000

# GitHub token (for cloning private repo to enable code-aware AI chat)
GITHUB_TOKEN=ghp_your_token_here

# E-Claw API (for AI to query server logs via curl)
ECLAW_API_URL=https://eclawbot.com
LOG_DEVICE_ID=your-device-id
LOG_DEVICE_SECRET=your-device-secret

# PostgreSQL connection (for AI to query DB via db_query.py)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Claude Code OAuth Token (used by Claude CLI for authentication)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
