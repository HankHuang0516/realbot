{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "claude-cli-proxy/Dockerfile",
    "watchPatterns": ["claude-cli-proxy/**"]
  },
  "deploy": {
    "startCommand": "python -m uvicorn proxy:app --host 0.0.0.0 --port ${PORT:-4000}",
    "healthcheckPath": "/health"
  }
}
