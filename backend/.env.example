# Server Configuration
PORT=3000
NODE_ENV=development

# Security (auto-generated if not set)
JWT_SECRET=your-secure-jwt-secret-here
WEBHOOK_SECRET=your-secure-webhook-secret-here
SEAL_KEY=your-64-hex-char-seal-key-here

# Flickr (for chat photo storage)
FLICKR_API_KEY=your-flickr-api-key
FLICKR_API_SECRET=your-flickr-api-secret
FLICKR_OAUTH_TOKEN=your-flickr-oauth-token
FLICKR_OAUTH_TOKEN_SECRET=your-flickr-oauth-token-secret

# Regression test — bot API response rate
TEST_DEVICE_ID=your-test-device-id

# Broadcast test device
BROADCAST_TEST_DEVICE_ID=your-broadcast-test-device-id
BROADCAST_TEST_DEVICE_SECRET=your-broadcast-test-device-secret

# AI Support — Direct Anthropic API (priority: Anthropic > Proxy > fallback)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# AI Support — Claude CLI proxy (legacy, used when ANTHROPIC_API_KEY is not set)
CLAUDE_CLI_PROXY_URL=http://claude-cli-proxy.railway.internal:4000
SUPPORT_API_KEY=your-shared-secret-here

# OAuth Social Login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# GitHub (for AI assistant to create issues)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=HankHuang0516/realbot

# X (Twitter) API — OAuth 1.0a for publishing
X_CONSUMER_KEY=your-x-consumer-key
X_CONSUMER_SECRET=your-x-consumer-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# DEV.to (Forem API) — Developer community publishing
DEVTO_API_KEY=your-devto-api-key

# WordPress.com — Blog publishing (OAuth2 Bearer token)
WORDPRESS_ACCESS_TOKEN=your-wordpress-access-token

# Telegraph (Telegra.ph) — Instant publishing (optional, auto-creates account if not set)
TELEGRAPH_ACCESS_TOKEN=

# Qiita — Japan developer platform (Bearer token)
QIITA_ACCESS_TOKEN=your-qiita-access-token

# WeChat Official Account (微信公眾號) — China content platform
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# Tumblr (API v2, OAuth 1.0a)
TUMBLR_CONSUMER_KEY=your-tumblr-consumer-key
TUMBLR_CONSUMER_SECRET=your-tumblr-consumer-secret
TUMBLR_ACCESS_TOKEN=your-tumblr-access-token
TUMBLR_ACCESS_TOKEN_SECRET=your-tumblr-access-token-secret

# Reddit (OAuth2 script app)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password

# LinkedIn (OAuth2 Bearer — token from developer.linkedin.com)
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_URN=urn:li:person:your-person-id

# Mastodon (any instance)
MASTODON_ACCESS_TOKEN=your-mastodon-access-token
MASTODON_INSTANCE_URL=https://mastodon.social

# Publisher API auth (optional — if not set, publisher endpoints are public)
PUBLISHER_API_KEY=your-publisher-api-key
