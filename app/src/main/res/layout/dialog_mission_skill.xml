<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/skill_template"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <!-- Selected template indicator (hidden until a template is chosen) -->
    <LinearLayout
        android:id="@+id/layoutSelectedTemplate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#10000000"
        android:padding="10dp"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSelectedTemplate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangeTemplate"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/skill_template_change"
            android:textSize="11sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBrowseTemplates"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/mission_browse_templates"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:id="@+id/layoutRequiredVarsWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1AFF9800"
        android:padding="10dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvRequiredVarsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/skill_required_vars_title"
            android:textColor="@color/priority_high"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvRequiredVarsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/priority_high"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToEnvVars"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/skill_go_to_env_vars"
            android:textSize="11sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />

    </LinearLayout>

    <EditText
        android:id="@+id/etTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/skill_title_hint"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/skill_url_hint"
        android:inputType="textUri"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etSteps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/skill_steps_hint"
        android:inputType="textMultiLine"
        android:minLines="3"
        android:maxLines="6"
        android:gravity="top|start"
        android:scrollbars="vertical"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/category_label"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/assign_entity_multi"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/entityCheckboxContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</LinearLayout>
