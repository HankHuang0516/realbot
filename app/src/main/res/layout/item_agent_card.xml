<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Drag Handle + Icon + Name + State Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Drag Handle (visible only in edit mode) -->
            <ImageView
                android:id="@+id/ivDragHandle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="@string/drag_to_reorder"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                app:tint="@color/text_disabled"/>

            <!-- Entity Avatar (tap to change) -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/avatarContainer">

                <TextView
                    android:id="@+id/tvEntityIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="🦞"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <ImageView
                    android:id="@+id/imgEntityAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Name + ID -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvEntityName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entity Name"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvEntityId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#0"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- State Badge -->
            <TextView
                android:id="@+id/tvStateBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="IDLE"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:background="@drawable/badge_background" />

            <!-- Channel Badge (visible only for channel-bound entities) -->
            <TextView
                android:id="@+id/tvChannelBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="⚡ Channel"
                android:textColor="@color/success_light"
                android:textSize="11sp"
                android:background="@drawable/badge_channel_background"
                android:visibility="gone" />

            <!-- E2EE Badge (visible only for E2EE-capable channel entities) -->
            <TextView
                android:id="@+id/tvE2eeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="🔒 E2EE"
                android:textColor="#60A5FA"
                android:textSize="11sp"
                android:background="@drawable/badge_e2ee_background"
                android:visibility="gone" />

        </LinearLayout>

        <!-- XP/Level Bar -->
        <LinearLayout
            android:id="@+id/xpBarRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lv.1"
                android:textColor="@color/warning_gold"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/xpProgressBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:trackThickness="6dp"
                app:trackCornerRadius="3dp"
                app:indicatorColor="@color/warning_gold"
                app:trackColor="@color/divider"/>

            <TextView
                android:id="@+id/tvXpText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/100 XP"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- Public Code (cross-device messaging) -->
        <LinearLayout
            android:id="@+id/publicCodeRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvPublicCodeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/public_code_label"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvPublicCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/badge_public_code_background"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:drawablePadding="6dp" />

        </LinearLayout>

        <!-- Last Message Bubble -->
        <LinearLayout
            android:id="@+id/messageBubble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/message_bubble_background">

            <TextView
                android:id="@+id/tvLastMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last message..."
                android:textColor="@color/text_on_surface"
                android:textSize="14sp"
                android:maxLines="3"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvMessageTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Just now"
                android:textColor="@color/text_disabled"
                android:textSize="11sp"
                android:gravity="end" />

        </LinearLayout>

        <!-- Action Buttons Row (visible only in edit mode) -->
        <!-- M3 guideline: max 2 visible actions + overflow menu -->
        <LinearLayout
            android:id="@+id/editActionsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <!-- Refresh Connection Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefreshEntity"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/refresh_connection"
                android:textSize="13sp"
                android:textColor="?attr/colorPrimary"
                app:icon="@drawable/ic_refresh"
                app:iconSize="18dp"
                app:iconTint="?attr/colorPrimary"
                app:strokeColor="?attr/colorPrimary"
                app:cornerRadius="20dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <!-- Remove Entity Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoveEntity"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/remove_entity"
                android:textSize="13sp"
                android:textColor="?attr/colorError"
                app:icon="@drawable/ic_delete"
                app:iconSize="18dp"
                app:iconTint="?attr/colorError"
                app:strokeColor="?attr/colorError"
                app:rippleColor="?attr/colorErrorContainer"
                app:cornerRadius="20dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <!-- Overflow Menu (Cross-Device Msg, Agent Card) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOverflow"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/more_options"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="40dp"
                android:minHeight="40dp"
                app:icon="@drawable/ic_more_vert"
                app:iconSize="20dp"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:iconPadding="0dp"
                app:iconGravity="textStart"
                app:cornerRadius="20dp"
                style="@style/Widget.Material3.Button.TextButton" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
